meta {
  name: Refresh Token
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: none
  auth: none
}

script:post-response {
  const body = res.getBody();
  if (body && body.data && body.data.sessionToken) {
    bru.setVar("accessToken", body.data.sessionToken);
    bru.setEnvVar("accessToken", body.data.sessionToken);
  }
}
