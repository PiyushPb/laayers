meta {
  name: Toggle Module
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/api/v1/workspaces/:workspaceId/modules/:moduleKey
  body: json
  auth: bearer
}

params:path {
  workspaceId: {{workspaceId}}
  moduleKey: blogs
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "enabled": true
  }
}
