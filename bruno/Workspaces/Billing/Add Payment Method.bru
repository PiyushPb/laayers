meta {
  name: Add Payment Method
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/workspaces/:workspaceId/billing/payment-methods
  body: json
  auth: bearer
}

params:path {
  workspaceId: {{workspaceId}}
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "token": "tok_visa"
  }
}
