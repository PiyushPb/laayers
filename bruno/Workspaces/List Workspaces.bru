meta {
  name: List Workspaces
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/workspaces
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  const data = res.getBody().data;
  if (data && data.workspaces && data.workspaces.length > 0) {
    const firstWorkspaceId = data.workspaces[0].id;
    bru.setVar("workspaceId", firstWorkspaceId);
    bru.setEnvVar("workspaceId", firstWorkspaceId);
  }
}
