meta {
  name: Create Workspace
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/workspaces
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "New Workspace"
  }
}

script:post-response {
  if (res.getBody().data && res.getBody().data.workspace && res.getBody().data.workspace.id) {
    bru.setVar("workspaceId", res.getBody().data.workspace.id);
    bru.setEnvVar("workspaceId", res.getBody().data.workspace.id);
  }
}
