{
  "name": "laayers",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run check-types",
    "db:generate": "pnpm --filter @layers/database db:generate",
    "db:migrate": "pnpm --filter @layers/database db:migrate",
    "db:push": "pnpm --filter @layers/database db:push",
    "db:studio": "pnpm --filter @layers/database db:studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:stress": "vitest run tests/stress"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2",
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
